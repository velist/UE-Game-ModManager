<Window x:Class="UEModManager.Views.ConfigManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="配置文件管理器" Height="560" Width="860"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBaseBrush}"
        Style="{StaticResource CyberDarkWindow}">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow"/>
        <CommandBinding Command="{x:Static SystemCommands.MinimizeWindowCommand}" Executed="OnMinimizeWindow"/>
    </Window.CommandBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════ 左侧：配置文件列表 ═══════ -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- 标题 -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,0">
                    <TextBlock Text="配置文件" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource Text600Brush}" Margin="0,0,0,4"/>
                    <Border CornerRadius="8" Background="{StaticResource BgBaseBrush}"
                            Padding="10,7" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{StaticResource Text500Brush}" VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBlock x:Name="FileCountText" Text="0 个文件" FontSize="12"
                                       Foreground="{StaticResource Text400Brush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource CyberBorderBrush}" Margin="16,12,16,8"/>

                <!-- 文件列表 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="8,0">
                    <StackPanel x:Name="FileListPanel"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══════ 右侧：文件详情 + 键值表 ═══════ -->
        <DockPanel Grid.Column="1">
            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="24,16" BorderBrush="{StaticResource CyberBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="FileNameText" Text="未选择文件" FontSize="17" FontWeight="Bold"
                                       Foreground="{StaticResource Text100Brush}" VerticalAlignment="Center"/>
                            <Border x:Name="FormatBadge" CornerRadius="4" Padding="8,3" Margin="12,0,0,0"
                                    Background="#1a06b6d4" VerticalAlignment="Center" Visibility="Collapsed">
                                <TextBlock x:Name="FormatText" Text="INI" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="FilePathText" Text="" FontSize="11"
                                   Foreground="{StaticResource Text500Brush}" Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="StatsText" Text="" FontSize="12"
                                   Foreground="{StaticResource Text400Brush}" VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                        <Border CornerRadius="8" Padding="14,8" Cursor="Hand"
                                MouseLeftButtonDown="PreviewMerge_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect ShadowDepth="0" BlurRadius="12"
                                                                      Color="#06b6d4" Opacity="0.5"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="预览合并" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource BgBaseBrush}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 表头 -->
            <Border DockPanel.Dock="Top" Padding="24,10" Background="#08ffffff">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Section" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource Text500Brush}"/>
                    <TextBlock Grid.Column="1" Text="Key" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource Text500Brush}"/>
                    <TextBlock Grid.Column="2" Text="Value" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource Text500Brush}"/>
                    <TextBlock Grid.Column="3" Text="来源 (MOD)" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource Text500Brush}" TextAlignment="Right"/>
                </Grid>
            </Border>

            <!-- 表体 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="EntryTablePanel"/>
            </ScrollViewer>
        </DockPanel>

        <!-- 加载遮罩 -->
        <Border x:Name="LoadingOverlay" Grid.ColumnSpan="2" Background="#80030303"
                Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="3"
                             Foreground="{StaticResource PrimaryBrush}"
                             Background="{StaticResource CyberBorderBrush}" BorderThickness="0"/>
                <TextBlock Text="正在加载配置..." FontSize="13" Foreground="{StaticResource Text400Brush}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
