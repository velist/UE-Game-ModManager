<Window x:Class="UEModManager.Views.GamePathDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="游戏路径配置" Height="600" Width="700"
        MinHeight="600" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource CyberDarkWindow}">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.MinimizeWindowCommand}" Executed="OnMinimizeWindow"/>
        <CommandBinding Command="{x:Static SystemCommands.MaximizeWindowCommand}" Executed="OnMaximizeWindow"/>
        <CommandBinding Command="{x:Static SystemCommands.RestoreWindowCommand}" Executed="OnRestoreWindow"/>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow"/>
    </Window.CommandBindings>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="配置游戏路径" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource Text100Brush}"/>
            <TextBlock Text="设置游戏安装路径、MOD 目录和备份目录" FontSize="13"
                       Foreground="{StaticResource Text500Brush}" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- 路径输入 -->
        <StackPanel Grid.Row="1">
            <!-- 游戏图标（非必填） -->
            <Border CornerRadius="12" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                    Padding="16" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 图标预览框 -->
                    <Border Grid.Column="0" x:Name="GameIconBorder" Width="64" Height="64"
                            CornerRadius="12" Background="{StaticResource BgBaseBrush}"
                            BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                            ClipToBounds="True" Cursor="Hand"
                            MouseLeftButtonDown="GameIcon_Click">
                        <Grid>
                            <Image x:Name="GameIconPreview" Stretch="UniformToFill"
                                   Visibility="Collapsed"/>
                            <StackPanel x:Name="GameIconPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🖼" FontSize="20" HorizontalAlignment="Center"
                                           Foreground="{StaticResource Text700Brush}" Opacity="0.5"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 图标信息 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="游戏图标" Foreground="{StaticResource Text200Brush}"
                                   FontSize="13" FontWeight="Medium"/>
                        <TextBlock Text="支持 PNG/JPG（非必选）" Foreground="{StaticResource Text500Brush}"
                                   FontSize="11" Margin="0,4,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="选择图片" Style="{StaticResource CyberSecondaryButton}"
                                    Height="28" Padding="12,0" FontSize="12"
                                    Click="GameIcon_Click"/>
                            <Button x:Name="ClearIconBtn" Content="清除" Style="{StaticResource CyberSecondaryButton}"
                                    Height="28" Padding="12,0" FontSize="12" Margin="8,0,0,0"
                                    Foreground="{StaticResource Text500Brush}"
                                    Visibility="Collapsed"
                                    Click="ClearGameIcon_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 游戏路径 -->
            <TextBlock Text="游戏安装路径" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="GamePathTextBox" Grid.Column="0" Style="{StaticResource CyberTextBox}"/>
                <Button Grid.Column="1" Content="浏览" Style="{StaticResource CyberSecondaryButton}"
                        Width="72" Height="40" Margin="8,0,0,0" Click="BrowseGamePath_Click"/>
            </Grid>

            <!-- MOD路径 -->
            <TextBlock Text="MOD 文件夹路径" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ModPathTextBox" Grid.Column="0" Style="{StaticResource CyberTextBox}"/>
                <Button Grid.Column="1" Content="浏览" Style="{StaticResource CyberSecondaryButton}"
                        Width="72" Height="40" Margin="8,0,0,0" Click="BrowseModPath_Click"/>
            </Grid>

            <!-- 备份路径 -->
            <TextBlock Text="备份文件夹路径" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="BackupPathTextBox" Grid.Column="0" Style="{StaticResource CyberTextBox}"/>
                <Button Grid.Column="1" Content="浏览" Style="{StaticResource CyberSecondaryButton}"
                        Width="72" Height="40" Margin="8,0,0,0" Click="BrowseBackupPath_Click"/>
            </Grid>
        </StackPanel>

        <!-- 搜索状态 -->
        <TextBlock x:Name="SearchStatusText" Grid.Row="2" FontSize="12"
                   Foreground="{StaticResource Text500Brush}" Margin="0,0,0,16"/>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Style="{StaticResource CyberSecondaryButton}"
                    Width="80" Height="36" Margin="0,0,12,0" Click="Cancel_Click"/>
            <Button Content="确认" Style="{StaticResource CyberPrimaryButton}"
                    Width="80" Height="36" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
