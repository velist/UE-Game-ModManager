<Window x:Class="UEModManager.Views.ConflictResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:UEModManager.Converters"
        Title="冲突检测结果" Height="540" Width="540"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource CyberModalWindow}">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow"/>
    </Window.CommandBindings>

    <Window.Resources>
        <converters:WinnerLoserBrushConverter x:Key="WinLoseBrush"/>
        <converters:WinnerLoserBgBrushConverter x:Key="WinLoseBgBrush"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 标题 + 冲突数 -->
            <RowDefinition Height="Auto"/>
            <!-- 说明 -->
            <RowDefinition Height="Auto"/>
            <!-- 冲突列表 -->
            <RowDefinition Height="*"/>
            <!-- 底部按钮 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ 标题行 ═══ -->
        <Border Grid.Row="0" Padding="24,20,24,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" FontSize="18" Foreground="#f59e0b"
                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="冲突检测结果" FontSize="17" FontWeight="SemiBold"
                           Foreground="{StaticResource Text100Brush}" VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <Border x:Name="ConflictCountBadge" Background="#28ef4444" CornerRadius="4"
                        Padding="8,3" VerticalAlignment="Center">
                    <TextBlock x:Name="ConflictCountText" Text="0 个冲突"
                               FontSize="12" FontWeight="SemiBold" Foreground="#ef4444"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══ 说明 ═══ -->
        <TextBlock Grid.Row="1" TextWrapping="Wrap"
                   Text="以下文件存在多个来源冲突，优先级高的包将覆盖低的"
                   FontSize="13" Foreground="{StaticResource Text400Brush}"
                   Margin="24,4,24,16"/>

        <!-- ═══ 冲突列表 ═══ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="24,0,24,0">
            <StackPanel x:Name="ConflictListPanel"/>
        </ScrollViewer>

        <!-- ═══ 底部按钮 ═══ -->
        <Border Grid.Row="3" Padding="24,16,24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" x:Name="AutoResolveButton" Click="AutoResolve_Click"
                        Style="{StaticResource CyberSecondaryButton}"
                        Height="36" Padding="14,0" Margin="0,0,10,0">
                    <TextBlock Text="自动解决全部" FontSize="13"/>
                </Button>
                <Button Grid.Column="2" x:Name="ApplyButton" Click="Apply_Click"
                        Style="{StaticResource CyberPrimaryButton}"
                        Height="38" Padding="16,0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="应用并部署" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
