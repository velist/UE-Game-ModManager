<Window x:Class="UEModManager.Views.SupabaseConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="账号服务设置" Height="450" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource CyberModalWindow}">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow"/>
    </Window.CommandBindings>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 + Demo 模式 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="账号服务设置" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource Text100Brush}" Margin="0,0,0,12"/>
            <CheckBox x:Name="DemoModeCheckBox" Content="使用离线账号模式（不连接云端）"
                      Style="{StaticResource CyberCheckBox}" Click="DemoModeCheckBox_Click"/>
        </StackPanel>

        <!-- 配置表单 -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="云端服务地址" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
            <TextBox x:Name="UrlTextBox" Style="{StaticResource CyberTextBox}"
                     TextChanged="TextBox_TextChanged" Margin="0,0,0,16"/>

            <TextBlock Text="访问密钥" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
            <TextBox x:Name="AnonKeyTextBox" Style="{StaticResource CyberTextBox}"
                     TextChanged="TextBox_TextChanged" Margin="0,0,0,16"/>

            <Button x:Name="TestButton" Content="测试连接"
                    Style="{StaticResource CyberSecondaryButton}"
                    Height="36" Width="100" HorizontalAlignment="Left"
                    Margin="0,0,0,8" Click="TestButton_Click"/>
            <TextBlock x:Name="StatusTextBlock" FontSize="12"
                       Foreground="{StaticResource Text500Brush}" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="CancelButton" Content="取消" Style="{StaticResource CyberSecondaryButton}"
                    Width="80" Height="36" Margin="0,0,12,0" Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="保存" Style="{StaticResource CyberPrimaryButton}"
                    Width="80" Height="36" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
