<Window x:Class="UEModManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:UEModManager.Converters"
        xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
        Title="爱酱MOD管理器"
        Icon="mnlogo.ico"
        Height="900" Width="1440"
        MinHeight="680" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBaseBrush}"
        Style="{StaticResource CyberDarkWindow}"
        PreviewMouseDown="MainWindow_PreviewMouseDown"
        SourceInitialized="Window_SourceInitialized">
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.MinimizeWindowCommand}" Executed="OnMinimizeWindow" />
        <CommandBinding Command="{x:Static SystemCommands.MaximizeWindowCommand}" Executed="OnMaximizeWindow" />
        <CommandBinding Command="{x:Static SystemCommands.RestoreWindowCommand}" Executed="OnRestoreWindow" />
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow" />
    </Window.CommandBindings>

    <!-- Body: CyberDarkWindow 样式已提供 TitleBar(36px) + 窗口控制按钮 -->
    <Grid>
        <!-- 主内容区 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="256"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ Sidebar (256px) ═══ -->
            <Border Grid.Column="0" Background="{StaticResource BgBaseBrush}"
                    BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">

                    <!-- UserArea (底部固定) -->
                    <Border DockPanel.Dock="Bottom" Padding="16"
                            BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="0,1,0,0">
                        <Border x:Name="UserBtn" CornerRadius="12" Padding="8" Cursor="Hand"
                                MouseLeftButtonDown="UserArea_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 用户头像 -->
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1">
                                    <TextBlock x:Name="UserAvatarIcon" Text="👤" FontSize="14"
                                               Foreground="{StaticResource Text500Brush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- 用户信息 -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock x:Name="UserNameText" Text="未登录"
                                               Foreground="{StaticResource Text300Brush}"
                                               FontSize="13" FontWeight="Medium"/>
                                    <TextBlock x:Name="UserStatusText" Text="点击登录账号"
                                               Foreground="{StaticResource Text600Brush}" FontSize="11"/>
                                </StackPanel>

                                <!-- 设置图标 (齿轮) -->
                                <Border Grid.Column="2" VerticalAlignment="Center" Cursor="Hand"
                                        MouseLeftButtonDown="SettingsIcon_Click">
                                    <Viewbox Width="16" Height="16">
                                        <Path Fill="{StaticResource Text600Brush}"
                                              Data="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/>
                                    </Viewbox>
                                </Border>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- DonateArea (底部固定，在 UserArea 上方) -->
                    <Border DockPanel.Dock="Bottom" Padding="16,12,16,8">
                        <Grid>
                            <Border x:Name="DonateBtn" CornerRadius="10" Padding="10,8" Cursor="Hand"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                                    MouseEnter="DonateBtn_MouseEnter"
                                    MouseLeave="DonateBtn_MouseLeave"
                                    MouseLeftButtonDown="DonateBtn_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- 爱心图标 -->
                                    <Viewbox Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                                                  Fill="#F43F5E"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="捐赠支持" FontSize="12" FontWeight="Medium"
                                               Foreground="{StaticResource Text400Brush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- 捐赠二维码 Popup -->
                            <Popup x:Name="DonatePopup" Placement="Right" PlacementTarget="{Binding ElementName=DonateBtn}"
                                   HorizontalOffset="12" VerticalOffset="-80"
                                   AllowsTransparency="True" PopupAnimation="Fade"
                                   StaysOpen="False">
                                <Border CornerRadius="16" Padding="20"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="24"
                                                          Color="{StaticResource PrimaryColor}" Opacity="0.25"/>
                                    </Border.Effect>
                                    <StackPanel Width="220">
                                        <!-- 标题 -->
                                        <TextBlock Text="支持MOD管理器开发" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text100Brush}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="请我喝一杯咖啡~" FontSize="12"
                                                   Foreground="{StaticResource Text500Brush}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <!-- 二维码 -->
                                        <Border CornerRadius="12" Background="White" Padding="12"
                                                HorizontalAlignment="Center">
                                            <Image Source="捐赠.png" Width="180" Height="180"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <!-- 底部提示 -->
                                        <TextBlock Text="微信扫一扫" FontSize="11"
                                                   Foreground="{StaticResource Text600Brush}"
                                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>

                    <!-- 侧边栏可滚动内容 -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Style="{StaticResource CyberScrollViewer}">
                        <StackPanel>

                            <!-- SidebarHeader: Logo + GameSwitcher -->
                            <StackPanel Margin="24,24,24,8">
                                <!-- Logo -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Image Source="pack://application:,,,/mnlogo.ico" Width="32" Height="32"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Effect>
                                            <DropShadowEffect ShadowDepth="0" BlurRadius="12" Color="{StaticResource PrimaryColor}" Opacity="0.25"/>
                                        </Image.Effect>
                                    </Image>
                                    <TextBlock x:Name="SidebarLogoText" Text="爱酱MOD管理器" Foreground="{StaticResource Text100Brush}"
                                               FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Margin="12,0,0,0" />
                                </StackPanel>

                                <!-- GameSwitcher -->
                                <StackPanel>
                                    <TextBlock x:Name="CurrentGameLabel" Text="当前游戏" Foreground="{StaticResource Text600Brush}"
                                               FontSize="11" FontWeight="Medium" Margin="0,0,0,6"/>
                                    <Border x:Name="GameSwitcherBtn" CornerRadius="12" Padding="12,8"
                                            Background="{StaticResource SurfaceBrush}" Cursor="Hand"
                                            BorderBrush="#27272A99" BorderThickness="1"
                                            MouseLeftButtonDown="GameSwitcher_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8"
                                                    Background="{StaticResource SurfaceHoverBrush}" ClipToBounds="True">
                                                <Grid>
                                                    <Image x:Name="CurrentGameIcon" Stretch="UniformToFill"
                                                           Visibility="Collapsed"/>
                                                    <TextBlock x:Name="CurrentGameIconPlaceholder" Text="🎮" FontSize="16"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock x:Name="CurrentGameName" Grid.Column="1" Text="请选择游戏"
                                                       Foreground="{StaticResource Text200Brush}"
                                                       FontSize="13" FontWeight="Medium"
                                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Viewbox Grid.Column="2" Width="14" Height="14" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M7,15 L12,20 L17,15 M7,9 L12,4 L17,9"
                                                          Stroke="{StaticResource Text600Brush}" StrokeThickness="2"
                                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- NavSection -->
                            <StackPanel Margin="16">

                                <!-- 库 Group -->
                                <StackPanel Margin="0,0,0,24">
                                    <TextBlock x:Name="NavLibraryHeader" Text="库" Foreground="{StaticResource Text600Brush}"
                                               FontSize="11" FontWeight="Bold" Margin="12,0,0,8"
                                              />

                                    <!-- 全部 MOD (active) -->
                                    <Border x:Name="NavAllMods" CornerRadius="8" Padding="8,8,12,8" Margin="0,0,0,4"
                                            Background="{StaticResource SurfaceHoverBrush}" Cursor="Hand"
                                            BorderBrush="#27272A80" BorderThickness="1"
                                            MouseLeftButtonDown="NavItem_Click" Tag="全部">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Viewbox Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M12,2 L2,7 L12,12 L22,7 Z M2,12 L12,17 L22,12 M2,17 L12,22 L22,17"
                                                              Stroke="{StaticResource PrimaryLightBrush}" StrokeThickness="2"
                                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock x:Name="NavAllModsText" Text="全部 MOD" Foreground="{StaticResource PrimaryLightBrush}"
                                                           FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock x:Name="NavAllCount" Grid.Column="1" Text="0"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- 已启用 -->
                                    <Border x:Name="NavEnabled" CornerRadius="8" Padding="8,8,12,8" Margin="0,0,0,4"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="NavItem_Click" Tag="已启用">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Viewbox Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M22,12 A10,10 0 1,1 2,12 A10,10 0 1,1 22,12 Z M9,12 L11,14 L15,10"
                                                              Stroke="{StaticResource Text500Brush}" StrokeThickness="2"
                                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock x:Name="NavEnabledText" Text="已启用" Foreground="{StaticResource Text500Brush}"
                                                           FontSize="13" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock x:Name="NavEnabledCount" Grid.Column="1" Text="0"
                                                       Foreground="{StaticResource Text500Brush}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- 已禁用 -->
                                    <Border x:Name="NavDisabled" CornerRadius="8" Padding="8,8,12,8"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="NavItem_Click" Tag="已禁用">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Viewbox Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M22,2 L2,22"
                                                              Stroke="{StaticResource Text500Brush}" StrokeThickness="2"
                                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock x:Name="NavDisabledText" Text="已禁用" Foreground="{StaticResource Text500Brush}"
                                                           FontSize="13" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock x:Name="NavDisabledCount" Grid.Column="1" Text="0"
                                                       Foreground="{StaticResource Text500Brush}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!-- 分类目录 Group -->
                                <StackPanel>
                                    <Grid Margin="12,0,12,8">
                                        <TextBlock x:Name="NavCategoriesHeader" Text="分&#x2009;类&#x2009;目&#x2009;录" Foreground="{StaticResource Text600Brush}"
                                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center"
                                                  />
                                        <Border HorizontalAlignment="Right" Cursor="Hand"
                                                MouseLeftButtonDown="AddCategory_Click">
                                            <TextBlock Text="＋" FontSize="14" Foreground="{StaticResource Text600Brush}"/>
                                        </Border>
                                    </Grid>

                                    <!-- 分类列表 -->
                                    <ListBox x:Name="CategoryList" Background="Transparent" BorderThickness="0"
                                             SelectionMode="Single"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                             ScrollViewer.CanContentScroll="False"
                                             SelectionChanged="CategoryList_SelectionChanged"
                                             MouseMove="CategoryList_MouseMove"
                                             MouseUp="CategoryList_MouseUp"
                                             AllowDrop="True"
                                             DragEnter="CategoryList_DragEnter"
                                             DragOver="CategoryList_DragOver"
                                             Drop="CategoryList_Drop"
                                             ContextMenuOpening="CategoryList_ContextMenuOpening">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="AllowDrop" Value="True"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border Name="CatBorder" Background="Transparent"
                                                                    CornerRadius="8" Padding="8,8,12,8" Margin="0,2">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                        <!-- 分类色点 -->
                                                                        <Ellipse Width="8" Height="8"
                                                                                 Stroke="{StaticResource PrimaryBrush}"
                                                                                 StrokeThickness="2" Fill="Transparent"
                                                                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                                        <TextBlock Text="{Binding DisplayText}"
                                                                                   Foreground="{StaticResource Text500Brush}"
                                                                                   FontSize="13" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Count}"
                                                                               Foreground="{StaticResource Text500Brush}"
                                                                               FontSize="12" VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="CatBorder" Property="Background"
                                                                            Value="{StaticResource SurfaceHoverBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="CatBorder" Property="Background"
                                                                            Value="{StaticResource SurfaceHoverBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ContextMenu>
                                            <ContextMenu Style="{StaticResource CyberContextMenu}" Opened="CategoryContextMenu_Opened">
                                                <MenuItem x:Name="CtxMenuRename" Header="重命名" Click="RenameCategoryMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                                <MenuItem x:Name="CtxMenuDelete" Header="删除" Click="DeleteCategoryMenuItem_Click" Style="{StaticResource CyberMenuItemDanger}"/>
                                            </ContextMenu>
                                        </ListBox.ContextMenu>
                                    </ListBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- ═══ 游戏方案选择器 ═══ -->
                            <Border Margin="24,16,24,24" Padding="0" BorderBrush="#27272a" BorderThickness="0,1,0,0">
                                <StackPanel Margin="0,16,0,0">
                                    <TextBlock Text="MOD 配置方案" Foreground="{StaticResource Text600Brush}"
                                               FontSize="11" FontWeight="Medium" Margin="0,0,0,8"/>
                                    <Border x:Name="ProfileSelectorBtn" CornerRadius="10" Padding="12,10"
                                            Background="{StaticResource SurfaceBrush}" Cursor="Hand"
                                            BorderBrush="#27272A99" BorderThickness="1"
                                            MouseLeftButtonDown="ProfileSelector_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- 方案图标 -->
                                            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7"
                                                    Background="#1a06b6d4">
                                                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- 方案名称 + 摘要 -->
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="ProfileSelectorName" Text="默认 MOD 方案"
                                                           Foreground="{StaticResource Text200Brush}"
                                                           FontSize="12" FontWeight="Medium"/>
                                                <TextBlock x:Name="ProfileSelectorSummary" Text=""
                                                           Foreground="{StaticResource Text500Brush}"
                                                           FontSize="10" Margin="0,1,0,0"/>
                                            </StackPanel>
                                            <!-- 展开箭头 -->
                                            <Viewbox Grid.Column="2" Width="12" Height="12" VerticalAlignment="Center" Margin="4,0,0,0">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M9,6 L15,12 L9,18"
                                                          Stroke="{StaticResource Text600Brush}" StrokeThickness="2"
                                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ═══ MainContent ═══ -->
            <Grid Grid.Column="1">
                <!-- 背景图片层 -->
                <Image x:Name="BgImage" Stretch="UniformToFill" Visibility="Collapsed"/>
                <!-- 背景纯色层 -->
                <Border x:Name="BgSolidLayer" Visibility="Collapsed"/>
                <!-- 背景渐变遮罩 -->
                <Border x:Name="BgOverlay" Visibility="Collapsed">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#20030303" Offset="0"/>
                            <GradientStop Color="#50030303" Offset="0.4"/>
                            <GradientStop Color="#A0030303" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <!-- 内容层 -->
            <DockPanel Background="Transparent" LastChildFill="True">

                <!-- Header (80px) -->
                <Border DockPanel.Dock="Top" Height="80" Padding="32,0">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 搜索框 -->
                        <Border Grid.Column="0" CornerRadius="12" Background="{StaticResource SurfaceBrush}"
                                Padding="12,0" Height="40" Width="320">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M19,11 A8,8 0 1,1 3,11 A8,8 0 1,1 19,11 Z M21,21 L16.65,16.65"
                                              Stroke="{StaticResource Text600Brush}" StrokeThickness="2"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                                <Grid>
                                    <TextBox x:Name="SearchBox" Text="" Background="Transparent" BorderThickness="0"
                                             Foreground="{StaticResource Text200Brush}" FontSize="14"
                                             VerticalAlignment="Center" Width="260" CaretBrush="{StaticResource PrimaryBrush}"
                                             TextChanged="SearchBox_TextChanged"
                                             GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"/>
                                    <TextBlock x:Name="SearchPlaceholder" Text="搜索 MOD 名称..."
                                               Foreground="{StaticResource Text600Brush}" FontSize="14"
                                               VerticalAlignment="Center" IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 右侧操作区 -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 视图切换 -->
                            <Border CornerRadius="8" Background="{StaticResource SurfaceBrush}"
                                    Padding="4" Margin="0,0,16,0"
                                    BorderBrush="#27272A99" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Border x:Name="GridViewBtn" Width="28" Height="28" CornerRadius="6"
                                            Background="{StaticResource CyberBorderBrush}" Cursor="Hand"
                                            MouseLeftButtonDown="CardViewBtn_Click">
                                        <Viewbox Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M3,3 H10 V10 H3 Z M14,3 H21 V10 H14 Z M14,14 H21 V21 H14 Z M3,14 H10 V21 H3 Z"
                                                      Stroke="{StaticResource PrimaryBrush}" StrokeThickness="2"
                                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                    <Border x:Name="ListViewBtnBorder" Width="28" Height="28" CornerRadius="6"
                                            Background="Transparent" Cursor="Hand"
                                            MouseLeftButtonDown="ListViewBtn_Click">
                                        <Viewbox Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M8,6 H21 M8,12 H21 M8,18 H21 M3,6 L3.01,6 M3,12 L3.01,12 M3,18 L3.01,18"
                                                      Stroke="{StaticResource Text600Brush}" StrokeThickness="2"
                                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 冲突检测 -->
                            <Border CornerRadius="12" Padding="12,8" Cursor="Hand" Margin="0,0,16,0"
                                    Background="#80181818"
                                    MouseLeftButtonDown="ConflictCheck_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M10.29,3.86 L1.82,18 A2,2 0 0,0 3.54,21 H20.46 A2,2 0 0,0 22.18,18 L13.71,3.86 A2,2 0 0,0 10.29,3.86 Z M12,9 V13 M12,17 L12.01,17"
                                                  Stroke="{StaticResource Text500Brush}" StrokeThickness="2"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock x:Name="ConflictCheckText" Text="冲突检测" Foreground="{StaticResource Text500Brush}"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- 分隔线 -->
                            <Border Width="1" Height="24" Background="{StaticResource CyberBorderBrush}" Margin="0,0,16,0"/>

                            <!-- 导入 -->
                            <Border CornerRadius="12" Background="{StaticResource ImportButtonGradient}" Padding="16,10"
                                    Cursor="Hand" Margin="0,0,16,0"
                                    MouseLeftButtonDown="ImportMod_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M21,15 V19 A2,2 0 0,1 19,21 H5 A2,2 0 0,1 3,19 V15 M7,10 L12,15 L17,10 M12,15 V3"
                                                  Stroke="{StaticResource BgBaseBrush}" StrokeThickness="2"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock x:Name="ImportModText" Text="导入" Foreground="{StaticResource BgBaseBrush}"
                                               FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- 分隔线（操作区 | 系统区） -->
                            <Border Width="1" Height="24" Background="{StaticResource CyberBorderBrush}" Margin="0,0,16,0"/>

                            <!-- 管理中心 -->
                            <Border CornerRadius="12" Background="{StaticResource SurfaceBrush}" Padding="16,10"
                                    Cursor="Hand" Margin="0,0,16,0"
                                    BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1"
                                    MouseLeftButtonDown="ManagementCenter_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Canvas Width="24" Height="24">
                                            <!-- Lucide settings-2 -->
                                            <Path Data="M20 7H12M20 7V3M20 7L16.5 10.5M4 17H12M4 17V21M4 17L7.5 13.5M20 17H12M20 17V21M20 17L16.5 13.5M4 7H12M4 7V3M4 7L7.5 10.5"
                                                  Stroke="{StaticResource Text400Brush}" StrokeThickness="2"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="高级管理" Foreground="{StaticResource Text200Brush}"
                                               FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- 启动游戏 -->
                            <Border CornerRadius="12" Padding="24,10"
                                    Cursor="Hand" MouseLeftButtonDown="LaunchGame_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource LaunchButtonGradient}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="20"
                                                                          Color="#10b981" Opacity="0.4"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M5,3 L19,12 L5,21 Z" Stroke="{StaticResource BgBaseBrush}" StrokeThickness="2"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock x:Name="LaunchGameText" Text="启动游戏" Foreground="{StaticResource BgBaseBrush}"
                                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- SubHeader -->
                <Border DockPanel.Dock="Top" Padding="32,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="ModCountText" Grid.Column="0" Text="全部 MOD"
                                   Foreground="{StaticResource Text100Brush}" FontSize="24" FontWeight="Bold"
                                   VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 全选 -->
                            <Border CornerRadius="8" Padding="8,6" Cursor="Hand" Margin="0,0,20,0"
                                    Background="#80181818"
                                    MouseLeftButtonDown="SelectAll_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M9,11 L12,14 L22,4 M21,12 V19 A2,2 0 0,1 19,21 H5 A2,2 0 0,1 3,19 V5 A2,2 0 0,1 5,3 H16"
                                                  Stroke="{StaticResource Text500Brush}" StrokeThickness="2"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock x:Name="SelectAllText" Text="全选" Foreground="{StaticResource Text500Brush}"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- 排序 -->
                            <Border CornerRadius="8" Padding="8,6" Cursor="Hand"
                                    Background="#80181818"
                                    MouseLeftButtonDown="SortButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="SortText" Text="排序: 名称"
                                               Foreground="{StaticResource Text500Brush}"
                                               FontSize="13" VerticalAlignment="Center"/>
                                    <Viewbox Width="10" Height="10" VerticalAlignment="Center" Margin="4,0,0,0">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M6,9 L12,15 L18,9"
                                                  Stroke="{StaticResource Text500Brush}" StrokeThickness="2"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </StackPanel>
                                <Border.ContextMenu>
                                    <ContextMenu x:Name="SortContextMenu" Style="{StaticResource CyberContextMenu}">
                                        <MenuItem Header="名称 ↑" Tag="Name_Asc" Click="SortMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                        <MenuItem Header="名称 ↓" Tag="Name_Desc" Click="SortMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                        <Separator Style="{StaticResource CyberMenuSeparator}"/>
                                        <MenuItem Header="安装日期 ↑" Tag="Date_Asc" Click="SortMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                        <MenuItem Header="安装日期 ↓" Tag="Date_Desc" Click="SortMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                        <Separator Style="{StaticResource CyberMenuSeparator}"/>
                                        <MenuItem Header="文件大小 ↑" Tag="Size_Asc" Click="SortMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                        <MenuItem Header="文件大小 ↓" Tag="Size_Desc" Click="SortMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═ ModGrid / ModList ═ -->
                <Grid x:Name="ModContentArea" Margin="26,8,26,16"
                      PreviewMouseDown="MainContentArea_PreviewMouseDown">
                        <!-- 卡片视图 -->
                        <ListBox x:Name="ModsCardView" Visibility="Visible"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 VirtualizingPanel.ScrollUnit="Pixel"
                                 VirtualizingPanel.CacheLength="1,1"
                                 VirtualizingPanel.CacheLengthUnit="Page"
                                 SelectionMode="Single"
                                 SizeChanged="ModsCardView_SizeChanged"
                                 PreviewMouseDown="MainContentArea_PreviewMouseDown">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <vwp:VirtualizingWrapPanel Orientation="Horizontal"
                                                                SpacingMode="Uniform"
                                                                StretchItems="False"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="CardRoot" Margin="6" ClipToBounds="True"
                                            CornerRadius="12" Background="{StaticResource SurfaceBrush}"
                                            BorderThickness="1" Width="{Binding CardWidth, RelativeSource={RelativeSource AncestorType=Window}}" Height="{Binding CardWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Cursor="Hand" MouseDown="ModCard_MouseDown"
                                            MouseEnter="ModCard_MouseEnter" MouseLeave="ModCard_MouseLeave">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#27272A" Opacity="0.6"/>
                                        </Border.BorderBrush>
                                        <Border.ContextMenu>
                                            <ContextMenu Style="{StaticResource CyberContextMenu}" Opened="ModContextMenu_Opened">
                                                <MenuItem Header="启用MOD" Click="EnableModMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                                <MenuItem Header="禁用MOD" Click="DisableModMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                                <Separator Style="{StaticResource CyberMenuSeparator}"/>
                                                <MenuItem Header="移动到分类" x:Name="MoveToCategoryMenuItem" Style="{StaticResource CyberMenuItem}"/>
                                                <Separator Style="{StaticResource CyberMenuSeparator}"/>
                                                <MenuItem Header="编辑" Click="RenameModMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                                <MenuItem Header="修改预览图" Click="ChangePreviewMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                                <Separator Style="{StaticResource CyberMenuSeparator}"/>
                                                <MenuItem Header="删除MOD" Click="DeleteModMenuItem_Click" Style="{StaticResource CyberMenuItemDanger}"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect ShadowDepth="0" BlurRadius="15"
                                                                                  Color="{StaticResource PrimaryColor}" Opacity="0.15"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect ShadowDepth="0" BlurRadius="15"
                                                                                  Color="{StaticResource PrimaryColor}" Opacity="0.1"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="6*"/>
                                                <RowDefinition Height="4*"/>
                                            </Grid.RowDefinitions>

                                            <!-- 缩略图区域 -->
                                            <Border Grid.Row="0" Background="{StaticResource BgBaseBrush}"
                                                    BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="0,0,0,1"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding PreviewImagePath, Converter={StaticResource AsyncImageConverter}}" Stretch="UniformToFill"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                                           Visibility="{Binding PreviewImagePath, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    <!-- 无图占位 -->
                                                    <Border Visibility="{Binding PreviewImagePath, Converter={StaticResource InverseNullToVisibilityConverter}}"
                                                            Background="#060608"
                                                            Margin="8" CornerRadius="8"
                                                            BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1">
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.3">
                                                            <Viewbox Width="32" Height="32" HorizontalAlignment="Center">
                                                                <Canvas Width="24" Height="24">
                                                                    <Path Data="M2,2 L22,22 M10.41,10.41 A2,2 0 1,1 7.58,7.58 M13.5,13.5 L6,21 M18,12.5 L21,15 M3.59,3.59 A2,2 0 0,0 3,5 V19 A2,2 0 0,0 5,21 H19 C19.55,21 20.05,20.78 20.41,20.41 M21,15 V5 A2,2 0 0,0 19,3 H9"
                                                                          Stroke="{StaticResource Text700Brush}" StrokeThickness="2"
                                                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                                </Canvas>
                                                            </Viewbox>
                                                            <TextBlock Text="暂无预览图" FontSize="10" FontWeight="Bold" Margin="0,6,0,0"
                                                                       Foreground="{StaticResource Text700Brush}"
                                                                       HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- 悬停遮罩 + 操作按钮 -->
                                                    <Border x:Name="HoverOverlay" Background="#00000099" Opacity="0"
                                                            IsHitTestVisible="False">
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                    Orientation="Horizontal">
                                                            <Border Width="36" Height="36" CornerRadius="18" Margin="6"
                                                                    Background="#27272ACC"
                                                                    IsHitTestVisible="True" Cursor="Hand"
                                                                    MouseDown="ModToggle_MouseDown" Tag="{Binding}"
                                                                    ToolTip="启用/禁用">
                                                                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="M18.36,6.64 A9,9 0 1,1 5.64,6.64 M12,2 V12"
                                                                              Stroke="#d4d4d8" StrokeThickness="2"
                                                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                                    </Canvas>
                                                                </Viewbox>
                                                            </Border>
                                                            <Border Width="36" Height="36" CornerRadius="18" Margin="6"
                                                                    Background="#27272ACC"
                                                                    IsHitTestVisible="True" Cursor="Hand"
                                                                    MouseDown="ModMore_MouseDown" Tag="{Binding}"
                                                                    ToolTip="更多操作">
                                                                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Path Data="M13,12 A1,1 0 1,1 11,12 A1,1 0 1,1 13,12 Z M20,12 A1,1 0 1,1 18,12 A1,1 0 1,1 20,12 Z M6,12 A1,1 0 1,1 4,12 A1,1 0 1,1 6,12 Z"
                                                                              Fill="#d4d4d8"/>
                                                                    </Canvas>
                                                                </Viewbox>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- v2.0 类型色标徽章 (左上角) -->
                                                    <Border CornerRadius="6" Padding="8,4"
                                                            HorizontalAlignment="Left" VerticalAlignment="Top"
                                                            Margin="8,8,0,0"
                                                            Background="{Binding DetectedKind, Converter={StaticResource PackageKindToBgBrushConverter}}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Ellipse Width="6" Height="6"
                                                                     Fill="{Binding DetectedKind, Converter={StaticResource PackageKindToBrushConverter}}"
                                                                     VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                            <TextBlock Text="{Binding DetectedKind, Converter={StaticResource PackageKindToLabelConverter}}"
                                                                       FontSize="10" FontWeight="Bold"
                                                                       Foreground="{Binding DetectedKind, Converter={StaticResource PackageKindToBrushConverter}}"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- 状态圆点指示器 (右上角) -->
                                                    <Border Width="24" Height="24" CornerRadius="12"
                                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                                            Margin="0,12,12,0">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="Black" Opacity="0.4"/>
                                                        </Border.Background>
                                                        <Ellipse Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="{StaticResource Text600Brush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                            <Setter Property="Fill" Value="{StaticResource StatusGreenBrush}"/>
                                                                            <Setter Property="Effect">
                                                                                <Setter.Value>
                                                                                    <DropShadowEffect ShadowDepth="0" BlurRadius="8"
                                                                                                      Color="{StaticResource StatusGreenColor}" Opacity="0.9"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- 卡片信息 -->
                                            <StackPanel Grid.Row="1" Margin="16" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                           FontSize="14" TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,0,8">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource Text200Brush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding RealName}" FontSize="11"
                                                           Foreground="{StaticResource Text600Brush}"
                                                           TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>
                                                <!-- 底部：大小 + 分类 -->
                                                <Grid>
                                                    <TextBlock Text="{Binding FormattedSize}" FontSize="12"
                                                               Foreground="{StaticResource Text500Brush}"
                                                               HorizontalAlignment="Left"/>
                                                    <TextBlock Text="{Binding PrimaryCategory}" FontSize="12"
                                                               Foreground="{StaticResource Text500Brush}"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- 列表视图 -->
                        <Grid x:Name="ModsListViewContainer" Visibility="Collapsed">
                            <!-- 列表表头 -->
                            <Grid Height="36" VerticalAlignment="Top" Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="" FontSize="12" Foreground="{StaticResource Text600Brush}"
                                           VerticalAlignment="Center" Margin="4,0"/>
                                <TextBlock Grid.Column="1" Text="名称" FontSize="12" Foreground="{StaticResource Text600Brush}"
                                           FontWeight="Medium" VerticalAlignment="Center" Margin="12,0"/>
                                <TextBlock Grid.Column="2" Text="状态" FontSize="12" Foreground="{StaticResource Text600Brush}"
                                           FontWeight="Medium" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="大小" FontSize="12" Foreground="{StaticResource Text600Brush}"
                                           FontWeight="Medium" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="分类" FontSize="12" Foreground="{StaticResource Text600Brush}"
                                           FontWeight="Medium" VerticalAlignment="Center"/>
                            </Grid>
                            <Border Height="1" VerticalAlignment="Top" Margin="0,36,0,0"
                                    Background="{StaticResource CyberBorderBrush}"/>

                            <ListView x:Name="ModsListView" Background="Transparent" BorderThickness="0"
                                      Margin="0,40,0,0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.CanContentScroll="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      VirtualizingPanel.ScrollUnit="Pixel"
                                      SelectionChanged="ModsListView_SelectionChanged"
                                      MouseDoubleClick="ModsListView_MouseDoubleClick"
                                      SelectionMode="Extended">
                            <ListView.ContextMenu>
                                <ContextMenu Style="{StaticResource CyberContextMenu}" Opened="ModContextMenu_Opened">
                                    <MenuItem Header="启用MOD" Click="EnableModMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                    <MenuItem Header="禁用MOD" Click="DisableModMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                    <Separator Style="{StaticResource CyberMenuSeparator}"/>
                                    <MenuItem Header="编辑" Click="RenameModMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                    <MenuItem Header="修改预览图" Click="ChangePreviewMenuItem_Click" Style="{StaticResource CyberMenuItem}"/>
                                    <Separator Style="{StaticResource CyberMenuSeparator}"/>
                                    <MenuItem Header="删除MOD" Click="DeleteModMenuItem_Click" Style="{StaticResource CyberMenuItemDanger}"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem" BasedOn="{StaticResource CyberListViewItem}">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="56" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 缩略图 -->
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                                Background="{StaticResource SurfaceBrush}" ClipToBounds="True"
                                                Cursor="Hand" MouseDown="ModCard_MouseDown" Tag="{Binding}">
                                            <Grid>
                                                <Image Source="{Binding PreviewImagePath, Converter={StaticResource AsyncImageConverterSmall}}" Stretch="UniformToFill"
                                                       Visibility="{Binding PreviewImagePath, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                <TextBlock Text="🖼" FontSize="16" Foreground="{StaticResource Text700Brush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding PreviewImagePath, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
                                            </Grid>
                                        </Border>

                                        <!-- 名称 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{StaticResource Text200Brush}"
                                                       FontSize="13" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding RealName}" FontSize="11"
                                                       Foreground="{StaticResource Text600Brush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- 状态 -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource Text600Brush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Fill" Value="{StaticResource StatusGreenBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding IsEnabled, Converter={StaticResource BoolToStatusTextConverter}}"
                                                       FontSize="12" Foreground="{StaticResource Text500Brush}"/>
                                        </StackPanel>

                                        <!-- 大小 -->
                                        <TextBlock Grid.Column="3" Text="{Binding FormattedSize}"
                                                   Foreground="{StaticResource Text500Brush}" FontSize="12"
                                                   VerticalAlignment="Center"/>

                                        <!-- 分类 -->
                                        <TextBlock Grid.Column="4" Text="{Binding PrimaryCategory}"
                                                   Foreground="{StaticResource Text500Brush}" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        </Grid>
                        <StackPanel x:Name="EmptyStatePanel" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="Collapsed" Margin="0,100,0,0">
                            <TextBlock x:Name="EmptyStateIcon" Text="📦" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock x:Name="EmptyStateTitle" Text="还没有 MOD" Foreground="{StaticResource Text400Brush}"
                                       FontSize="16" FontWeight="Medium" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="EmptyStateSubtitle" Text="点击「导入 MOD」按钮或拖拽文件到此处" Foreground="{StaticResource Text600Brush}"
                                       FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                </Grid>
            </DockPanel>
            </Grid>
        </Grid>

        <!-- 加载遮罩 (覆盖整个内容区) -->
        <Border x:Name="LoadingOverlay"
                Background="{StaticResource OverlayBrush}" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource CyberProgressBar}" IsIndeterminate="True"
                             Width="200" Margin="0,0,0,15"/>
                <TextBlock x:Name="LoadingText" Text="加载中..." Foreground="{StaticResource Text400Brush}"
                           FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>

</Window>
