<Window x:Class="UEModManager.Views.DatabaseConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数据库配置" Height="700" Width="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource CyberDarkWindow}">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.MinimizeWindowCommand}" Executed="OnMinimizeWindow"/>
        <CommandBinding Command="{x:Static SystemCommands.MaximizeWindowCommand}" Executed="OnMaximizeWindow"/>
        <CommandBinding Command="{x:Static SystemCommands.RestoreWindowCommand}" Executed="OnRestoreWindow"/>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow"/>
    </Window.CommandBindings>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <!-- 标题 -->
                <TextBlock Text="数据库配置" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource Text100Brush}" Margin="0,0,0,20"/>

                <!-- 提供商选择 -->
                <TextBlock Text="数据库提供商" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                <ComboBox x:Name="ProviderComboBox" Style="{StaticResource CyberComboBox}"
                          SelectionChanged="ProviderComboBox_SelectionChanged" Margin="0,0,0,4"/>
                <TextBlock x:Name="ProviderDescriptionTextBlock" FontSize="12"
                           Foreground="{StaticResource Text500Brush}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                <!-- 连接参数 -->
                <TextBlock Text="主机地址" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                <TextBox x:Name="HostTextBox" Style="{StaticResource CyberTextBox}" Margin="0,0,0,16"/>

                <TextBlock Text="数据库名" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                <TextBox x:Name="DatabaseTextBox" Style="{StaticResource CyberTextBox}" Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="用户名" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                        <TextBox x:Name="UsernameTextBox" Style="{StaticResource CyberTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="端口" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                        <TextBox x:Name="PortTextBox" Style="{StaticResource CyberTextBox}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="密码" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource CyberPasswordBox}" Margin="0,0,0,16"/>

                <!-- 选项 -->
                <CheckBox x:Name="EnableSslCheckBox" Content="启用 SSL 加密连接"
                          Style="{StaticResource CyberCheckBox}" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="连接超时(秒)" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                        <TextBox x:Name="ConnectionTimeoutTextBox" Style="{StaticResource CyberTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="命令超时(秒)" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                        <TextBox x:Name="CommandTimeoutTextBox" Style="{StaticResource CyberTextBox}"/>
                    </StackPanel>
                </Grid>

                <!-- 测试按钮 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="TestConnectionButton" Content="测试连接"
                            Style="{StaticResource CyberSecondaryButton}"
                            Height="36" Width="100" Margin="0,0,12,0" Click="TestConnection_Click"/>
                    <Button x:Name="InitializeDatabaseButton" Content="初始化数据库"
                            Style="{StaticResource CyberSecondaryButton}"
                            Height="36" Width="120" Click="InitializeDatabase_Click"/>
                </StackPanel>
                <TextBlock x:Name="TestResultTextBlock" FontSize="12"
                           Foreground="{StaticResource Text500Brush}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- 免费提供商列表 -->
                <ItemsControl x:Name="FreeProvidersItemsControl" Margin="0,0,0,20"/>

                <!-- 底部按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Style="{StaticResource CyberSecondaryButton}"
                            Width="80" Height="36" Margin="0,0,12,0" Click="Cancel_Click"/>
                    <Button Content="保存" Style="{StaticResource CyberPrimaryButton}"
                            Width="80" Height="36" Click="Save_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- 加载遮罩 -->
        <Grid x:Name="LoadingOverlay" Background="#E6030303" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Width="120" Height="4" IsIndeterminate="True"
                             Style="{StaticResource CyberProgressBar}" Margin="0,0,0,12"/>
                <TextBlock x:Name="LoadingText" Text="处理中..."
                           Foreground="{StaticResource Text300Brush}" FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
