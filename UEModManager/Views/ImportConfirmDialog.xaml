<Window x:Class="UEModManager.Views.ImportConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:UEModManager.Converters"
        Title="导入确认" Height="640" Width="500"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource CyberModalWindow}">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow"/>
    </Window.CommandBindings>

    <Window.Resources>
        <converters:PackageKindToBrushConverter x:Key="KindToBrush"/>
        <converters:PackageKindToBgBrushConverter x:Key="KindToBgBrush"/>
        <converters:PackageKindToLabelConverter x:Key="KindToLabel"/>
        <converters:FileSizeConverter x:Key="FileSizeConv"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 标题区 -->
            <RowDefinition Height="Auto"/>
            <!-- 文件信息卡片 -->
            <RowDefinition Height="Auto"/>
            <!-- 方案选择 -->
            <RowDefinition Height="Auto"/>
            <!-- 文件列表 -->
            <RowDefinition Height="*"/>
            <!-- 部署目标路径 -->
            <RowDefinition Height="Auto"/>
            <!-- 路径未配置警告 -->
            <RowDefinition Height="Auto"/>
            <!-- 冲突警告 -->
            <RowDefinition Height="Auto"/>
            <!-- 底部按钮 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ 标题区 ═══ -->
        <Border Grid.Row="0" Padding="24,20,24,12">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,10,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="导入确认" FontSize="17" FontWeight="SemiBold"
                               Foreground="{StaticResource Text100Brush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="StepIndicator" Text="步骤 2/2"
                           FontSize="12" Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ 说明文本 + 文件信息 ═══ -->
        <StackPanel Grid.Row="1" Margin="24,0,24,12">
            <TextBlock Text="检测到以下文件，请确认导入"
                       FontSize="13" Foreground="{StaticResource Text400Brush}" Margin="0,0,0,12"/>

            <!-- 压缩包信息卡片 -->
            <Border x:Name="ArchiveInfoCard" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}" Padding="14,10" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                               Foreground="{StaticResource Text400Brush}" Margin="0,0,10,0"
                               VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="ArchiveFileName" Text="" FontSize="13" FontWeight="Medium"
                                   Foreground="{StaticResource Text200Brush}"/>
                        <TextBlock x:Name="ArchiveFileInfo" Text="" FontSize="11"
                                   Foreground="{StaticResource Text500Brush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ═══ 导入到方案 ═══ -->
        <Border Grid.Row="2" Margin="24,0,24,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="加入 MOD 方案：" FontSize="13"
                           Foreground="{StaticResource Text300Brush}" VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox x:Name="ProfileSelector" Width="140" Height="30"
                          Style="{StaticResource CyberComboBox}"
                          SelectionChanged="ProfileSelector_SelectionChanged"/>
            </StackPanel>
        </Border>

        <!-- ═══ 文件列表 ═══ -->
        <Border Grid.Row="3" Margin="24,0,24,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 表头 -->
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="42"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="文件名" FontSize="11"
                               Foreground="{StaticResource Text500Brush}"/>
                    <TextBlock Grid.Column="1" Text="类型" FontSize="11"
                               Foreground="{StaticResource Text500Brush}" TextAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="大小" FontSize="11"
                               Foreground="{StaticResource Text500Brush}" TextAlignment="Right"/>
                    <TextBlock Grid.Column="3" Text="导入" FontSize="11"
                               Foreground="{StaticResource Text500Brush}" TextAlignment="Center"/>
                </Grid>

                <!-- 文件行列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="FileListPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══ 部署目标路径 ═══ -->
        <Border Grid.Row="4" Margin="24,12,24,0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}" Padding="16,12">
            <StackPanel>
                <TextBlock Text="将安装到这些位置" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource Text200Brush}" Margin="0,0,0,8"/>

                <StackPanel x:Name="ModPathRow" Orientation="Horizontal" Margin="0,0,0,4">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="MOD →" FontSize="11" Foreground="{StaticResource Text400Brush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="ModPathText" Text="未配置" FontSize="11"
                               Foreground="{StaticResource Text300Brush}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel x:Name="PluginPathRow" Orientation="Horizontal" Margin="0,0,0,4">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource PluginPurpleBrush}"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="插件 →" FontSize="11" Foreground="{StaticResource Text400Brush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="PluginPathText" Text="未配置" FontSize="11"
                               Foreground="{StaticResource Text300Brush}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel x:Name="ConfigPathRow" Orientation="Horizontal" Margin="0,0,0,4">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource ConfigAmberBrush}"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="配置文件 →" FontSize="11" Foreground="{StaticResource Text400Brush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="ConfigPathText" Text="未配置" FontSize="11"
                               Foreground="{StaticResource Text300Brush}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <TextBlock x:Name="EditPathLink" Text="修改路径" FontSize="11"
                           Foreground="{StaticResource PrimaryBrush}" Cursor="Hand"
                           Margin="0,4,0,0" MouseLeftButtonDown="EditPath_Click">
                    <TextBlock.TextDecorations>
                        <TextDecoration Location="Underline"/>
                    </TextBlock.TextDecorations>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ═══ 路径未配置警告 ═══ -->
        <Border x:Name="PathWarningBorder" Grid.Row="5" Margin="24,8,24,0"
                Visibility="Collapsed"
                Background="#1Af59e0b"
                BorderBrush="{StaticResource ConfigAmberBrush}" BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="⚠" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{StaticResource ConfigAmberBrush}"/>
                    <TextBlock x:Name="PathWarningText" Text="路径未配置"
                               FontSize="12" Foreground="{StaticResource ConfigAmberBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1" Content="设置路径" Click="ConfigurePath_Click"
                        Style="{StaticResource CyberSecondaryButton}" Padding="12,4"/>
            </Grid>
        </Border>

        <!-- ═══ 潜在冲突警告 ═══ -->
        <Border Grid.Row="6" x:Name="ConflictWarningPanel" Visibility="Collapsed"
                Margin="24,12,24,0">
            <Border Background="#18f59e0b" CornerRadius="{StaticResource RadiusSm}"
                    Padding="14,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠" FontSize="14" Foreground="#f59e0b"
                               Margin="0,0,8,0" VerticalAlignment="Top"/>
                    <StackPanel>
                        <TextBlock Text="潜在冲突" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#f59e0b" Margin="0,0,0,2"/>
                        <TextBlock x:Name="ConflictWarningText" TextWrapping="Wrap"
                                   FontSize="12" Foreground="{StaticResource Text400Brush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- ═══ 底部按钮 ═══ -->
        <Border Grid.Row="7" Padding="24,16,24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="← 返回" Click="BackButton_Click"
                        Style="{StaticResource CyberSecondaryButton}"
                        Width="80" Height="36" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="取消" Click="CancelButton_Click"
                        Style="{StaticResource CyberSecondaryButton}"
                        Width="70" Height="36" Margin="0,0,8,0"/>
                <Button Grid.Column="3" x:Name="ConfirmButton" Click="ConfirmButton_Click"
                        Style="{StaticResource CyberPrimaryButton}"
                        Height="38" Padding="16,0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="确认导入" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
