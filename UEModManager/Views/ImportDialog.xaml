<Window x:Class="UEModManager.Views.ImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="导入 MOD / 插件" Height="480" Width="520"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource CyberModalWindow}"
        AllowDrop="True"
        Drop="DropZone_Drop"
        DragOver="DropZone_DragOver">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow"/>
    </Window.CommandBindings>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <!-- 标题行 -->
            <RowDefinition Height="Auto"/>
            <!-- 拖拽区域 -->
            <RowDefinition Height="*"/>
            <!-- 自动类型检测 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ 标题行 ═══ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                       Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <TextBlock Text="导入 MOD / 插件" FontSize="17" FontWeight="SemiBold"
                       Foreground="{StaticResource Text100Brush}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ═══ 拖拽区域 ═══ -->
        <Border Grid.Row="1" x:Name="DropZoneBorder"
                Background="Transparent"
                BorderBrush="{StaticResource CyberBorderBrush}"
                BorderThickness="1.5"
                CornerRadius="{StaticResource RadiusMd}"
                Margin="0,0,0,20"
                Padding="24">
            <Grid>
                <!-- 正常状态 -->
                <StackPanel x:Name="NormalDropState"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- 上传图标 -->
                    <Border Width="56" Height="56" CornerRadius="12"
                            Background="#0d06b6d4" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="拖拽文件到此处" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource Text100Brush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>

                    <TextBlock Text="支持 .zip .rar .7z .pak .dll .ini .json"
                               FontSize="12" Foreground="{StaticResource Text500Brush}"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <!-- 浏览按钮 -->
                    <Button x:Name="BrowseButton" Click="BrowseButton_Click"
                            Style="{StaticResource CyberSecondaryButton}"
                            Width="140" Height="36" HorizontalAlignment="Center" Cursor="Hand">
                        <TextBlock Text="或点击浏览文件" FontSize="13"/>
                    </Button>
                </StackPanel>

                <!-- 拖拽悬停状态 -->
                <StackPanel x:Name="DragOverState" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                               Foreground="{StaticResource PrimaryLightBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="释放文件即可导入" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryLightBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 加载状态 -->
                <StackPanel x:Name="LoadingState" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                 Style="{StaticResource CyberProgressBar}" Margin="0,0,0,12"/>
                    <TextBlock x:Name="LoadingText" Text="正在分析文件..."
                               FontSize="13" Foreground="{StaticResource Text400Brush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ 自动类型检测 ═══ -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="自动类型检测" FontSize="12" Foreground="{StaticResource Text500Brush}"
                       Margin="0,0,0,10"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- MOD 文件 -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}" Padding="12,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="8" Height="8" Fill="#06b6d4" Margin="0,0,8,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="MOD 文件" FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource Text200Brush}"/>
                        </StackPanel>
                        <TextBlock Text=".pak .utoc .ucas" FontSize="11"
                                   Foreground="{StaticResource Text500Brush}"/>
                    </StackPanel>
                </Border>

                <!-- 插件 -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}" Padding="12,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="8" Height="8" Fill="#a855f7" Margin="0,0,8,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="插件" FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource Text200Brush}"/>
                        </StackPanel>
                        <TextBlock Text=".dll" FontSize="11"
                                   Foreground="{StaticResource Text500Brush}"/>
                    </StackPanel>
                </Border>

                <!-- 配置 -->
                <Border Grid.Column="4" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}" Padding="12,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="8" Height="8" Fill="#f59e0b" Margin="0,0,8,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="配置" FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource Text200Brush}"/>
                        </StackPanel>
                        <TextBlock Text=".ini .json .cfg" FontSize="11"
                                   Foreground="{StaticResource Text500Brush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
