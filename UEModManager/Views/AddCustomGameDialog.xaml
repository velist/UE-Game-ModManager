<Window x:Class="UEModManager.Views.AddCustomGameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加游戏" Height="540" Width="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
            CornerRadius="{StaticResource RadiusLg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 标题栏 -->
                <RowDefinition Height="*"/>    <!-- 内容 -->
                <RowDefinition Height="Auto"/> <!-- 底栏 -->
            </Grid.RowDefinitions>

            <!-- ── 标题栏 ── -->
            <Border Grid.Row="0" BorderBrush="#99272727" BorderThickness="0,0,0,1"
                    MouseDown="TitleBar_MouseDown">
                <Grid Margin="24,20">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="8"
                                Background="#1a06b6d4" Margin="0,0,12,0">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#06b6d4" Opacity="0.2"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="添加游戏" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource Text100Brush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Style="{StaticResource CyberGhostButton}" HorizontalAlignment="Right"
                            Width="28" Height="28" Padding="0" Click="CancelButton_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{StaticResource Text500Brush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ── 内容区 ── -->
            <StackPanel Grid.Row="1" Margin="24">
                <!-- 游戏图标区 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Width="64" Height="64" CornerRadius="12" Background="#060608"
                            BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1">
                        <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                   Foreground="{StaticResource Text700Brush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="自定义游戏" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text200Brush}"/>
                        <TextBlock Text="添加未预设的游戏配置" FontSize="12"
                                   Foreground="{StaticResource Text500Brush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- 游戏名称 -->
                <TextBlock Text="游戏名称" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                <TextBox x:Name="GameNameTextBox" Style="{StaticResource CyberTextBox}"
                         TextChanged="GameNameTextBox_TextChanged"/>
                <TextBlock x:Name="ValidationMessageText" FontSize="11"
                           Foreground="{StaticResource StatusRedBrush}" Margin="2,6,0,0"
                           Visibility="Collapsed"/>

                <!-- 游戏安装路径 -->
                <TextBlock Text="游戏安装路径" Style="{StaticResource CyberLabel}" Margin="0,16,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="GamePathTextBox" Grid.Column="0" Style="{StaticResource CyberTextBox}"/>
                    <Button Grid.Column="1" Content="浏览" Style="{StaticResource CyberSecondaryButton}"
                            Width="72" Height="40" Margin="8,0,0,0" Click="BrowseGamePath_Click"/>
                </Grid>

                <!-- 引擎类型 -->
                <TextBlock x:Name="EngineTypeLabel" Text="引擎类型" Style="{StaticResource CyberLabel}" Margin="0,16,0,6"/>
                <ComboBox x:Name="EngineTypeComboBox" Style="{StaticResource CyberComboBox}"
                          SelectedIndex="0" Height="40">
                    <ComboBoxItem Content="自动检测"/>
                    <ComboBoxItem Content="Unreal Engine"/>
                    <ComboBoxItem Content="Unity"/>
                    <ComboBoxItem Content="RE Engine"/>
                    <ComboBoxItem Content="Godot"/>
                    <ComboBoxItem Content="Decima"/>
                </ComboBox>
                <TextBlock x:Name="EngineDetectionHint" FontSize="11"
                           Foreground="{StaticResource Text500Brush}" Margin="2,4,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- ── 底部按钮 ── -->
            <Border Grid.Row="2" BorderBrush="#99272727" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,16">
                    <Button Content="取消" Style="{StaticResource CyberGhostButton}"
                            Margin="0,0,12,0" Click="CancelButton_Click"/>
                    <Button Content="添加" Style="{StaticResource CyberPrimaryButton}"
                            Width="80" Height="36" Click="ConfirmButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
