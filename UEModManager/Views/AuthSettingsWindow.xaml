<Window x:Class="UEModManager.Views.AuthSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="认证设置" Height="450" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource CyberModalWindow}">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow"/>
    </Window.CommandBindings>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 + 语言切换 -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="HeaderText" Text="认证模式设置" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource Text100Brush}"/>
            <Button x:Name="LangToggleButton" Content="EN" Style="{StaticResource CyberCompactButton}"
                    HorizontalAlignment="Right" Click="LangToggleButton_Click"/>
        </Grid>

        <!-- 认证模式选择 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <RadioButton x:Name="HybridModeRadio" Content="混合模式（推荐）" GroupName="AuthMode" IsChecked="True"
                         Foreground="{StaticResource Text200Brush}" FontSize="14" Margin="0,0,0,10"/>
            <RadioButton x:Name="OnlineOnlyRadio" Content="仅在线模式" GroupName="AuthMode"
                         Foreground="{StaticResource Text200Brush}" FontSize="14" Margin="0,0,0,10"/>
            <RadioButton x:Name="OfflineOnlyRadio" Content="仅离线模式" GroupName="AuthMode"
                         Foreground="{StaticResource Text200Brush}" FontSize="14"/>
        </StackPanel>

        <!-- 网络状态 -->
        <Border Grid.Row="2" Background="{StaticResource BgBaseBrush}" CornerRadius="{StaticResource RadiusMd}"
                BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1" Padding="16" Margin="0,0,0,20">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock x:Name="NetworkLabelText" Text="网络状态：" FontSize="13"
                               Foreground="{StaticResource Text400Brush}"/>
                    <TextBlock x:Name="NetworkStatusText" Text="检测中..." FontSize="13"
                               Foreground="{StaticResource StatusGreenBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="RefreshNetworkButton" Content="刷新状态"
                            Style="{StaticResource CyberSecondaryButton}"
                            Height="32" Width="90" Margin="0,0,8,0" Click="RefreshNetwork_Click"/>
                    <Button x:Name="TestConnectionButton" Content="测试连接"
                            Style="{StaticResource CyberSecondaryButton}"
                            Height="32" Width="90" Click="TestConnection_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="取消" Style="{StaticResource CyberSecondaryButton}"
                    Width="80" Height="36" Margin="0,0,12,0" Click="Cancel_Click"/>
            <Button x:Name="SaveButton" Content="保存" Style="{StaticResource CyberPrimaryButton}"
                    Width="80" Height="36" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
