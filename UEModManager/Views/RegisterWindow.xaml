<Window x:Class="UEModManager.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="用户注册 - 爱酱MOD管理器" Height="640" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="#030303"
        ResizeMode="NoResize"
        Style="{StaticResource CyberBorderlessWindow}"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid>
        <!-- 背景遮罩层 -->
        <Border Background="#CC000000"/>

        <!-- 主内容卡片 -->
        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource RadiusLg}" Width="384"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- 头部 -->
                    <RowDefinition Height="Auto"/> <!-- 表单 -->
                </Grid.RowDefinitions>

                <!-- ── 头部区域 ── -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="32">
                    <!-- 图标 -->
                    <Border Width="48" Height="48" CornerRadius="12"
                            Background="#1a06b6d4" HorizontalAlignment="Center"
                            Margin="0,0,0,8">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#06b6d4" Opacity="0.2"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <TextBlock Text="&#xE8FA;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- 标题 -->
                    <TextBlock x:Name="SubtitleText" Text="注册新账号" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource Text100Brush}" HorizontalAlignment="Center"/>
                    <!-- 副标题 -->
                    <TextBlock Text="创建账号以同步云端MOD配置" FontSize="12"
                               Foreground="{StaticResource Text500Brush}"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- ── 表单区域 ── -->
                <StackPanel Grid.Row="1" Margin="32,0,32,32">
                    <!-- 语言切换 -->
                    <Button x:Name="LangToggleButton" Content="EN"
                            Style="{StaticResource CyberCompactButton}"
                            HorizontalAlignment="Right" Margin="0,0,0,12"
                            Click="LangToggleButton_Click"/>

                    <!-- 邮箱输入 -->
                    <TextBlock x:Name="EmailLabel" Text="邮箱地址 *"
                               Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                    <TextBox x:Name="EmailTextBox" Style="{StaticResource CyberTextBox}"/>

                    <!-- 用户名输入 -->
                    <TextBlock x:Name="UsernameLabel" Text="用户名（可选）"
                               Style="{StaticResource CyberLabel}" Margin="0,16,0,6"/>
                    <TextBox x:Name="UsernameTextBox" Style="{StaticResource CyberTextBox}" MaxLength="20"/>

                    <!-- 密码输入 -->
                    <TextBlock x:Name="PasswordLabel" Text="密码 *"
                               Style="{StaticResource CyberLabel}" Margin="0,16,0,6"/>
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource CyberPasswordBox}"/>

                    <!-- 确认密码 -->
                    <TextBlock x:Name="ConfirmPasswordLabel" Text="确认密码 *"
                               Style="{StaticResource CyberLabel}" Margin="0,16,0,6"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource CyberPasswordBox}"/>

                    <!-- 密码强度提示 -->
                    <TextBlock x:Name="PasswordStrengthText"
                               Text="密码至少8位，建议包含字母、数字和特殊字符"
                               FontSize="11" Foreground="{StaticResource Text500Brush}"
                               TextWrapping="Wrap" Margin="0,8,0,0"/>

                    <!-- 用户协议 -->
                    <CheckBox x:Name="AgreeCheckBox" Style="{StaticResource CyberCheckBox}"
                              Margin="0,16,0,0">
                        <CheckBox.Content>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource Text400Brush}">
                                <Run Text="我已阅读并同意"/>
                                <Hyperlink x:Name="UserAgreementLink" Click="UserAgreementLink_Click"
                                           Foreground="{StaticResource PrimaryBrush}" TextDecorations="None">
                                    <Run Text="用户协议"/>
                                </Hyperlink>
                                <Run Text="和"/>
                                <Hyperlink x:Name="PrivacyPolicyLink" Click="PrivacyPolicyLink_Click"
                                           Foreground="{StaticResource PrimaryBrush}" TextDecorations="None">
                                    <Run Text="隐私政策"/>
                                </Hyperlink>
                            </TextBlock>
                        </CheckBox.Content>
                    </CheckBox>

                    <!-- 注册按钮 -->
                    <Button x:Name="RegisterButton" Content="注 册"
                            Style="{StaticResource CyberPrimaryButton}"
                            Margin="0,20,0,0"
                            Click="RegisterButton_Click"/>

                    <!-- 返回登录 -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                        <TextBlock Text="已有账号？" FontSize="12"
                                   Foreground="{StaticResource Text500Brush}" VerticalAlignment="Center"/>
                        <Button x:Name="BackToLoginButton" Content="立即登录"
                                Style="{StaticResource CyberLinkButton}"
                                Margin="4,0,0,0"
                                Click="BackToLoginButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 关闭按钮 -->
        <Button Style="{StaticResource CyberGhostButton}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,16,16,0" Width="28" Height="28" Padding="0"
                Command="{x:Static SystemCommands.CloseWindowCommand}">
            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                       Foreground="{StaticResource Text500Brush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>

        <!-- 加载遮罩 -->
        <Grid x:Name="LoadingOverlay" Background="#E6030303" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Width="120" Height="4" IsIndeterminate="True"
                             Style="{StaticResource CyberProgressBar}" Margin="0,0,0,12"/>
                <TextBlock x:Name="LoadingText" Text="正在创建账户..."
                           Foreground="{StaticResource Text300Brush}" FontSize="13"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
