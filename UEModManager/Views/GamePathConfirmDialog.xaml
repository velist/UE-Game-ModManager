<Window x:Class="UEModManager.Views.GamePathConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认游戏路径" Width="600" Height="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
            CornerRadius="{StaticResource RadiusLg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" BorderBrush="#99272727" BorderThickness="0,0,0,1"
                    MouseDown="TitleBar_MouseDown">
                <Grid Margin="24,16">
                    <TextBlock Text="确认游戏路径" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource Text100Brush}" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource CyberGhostButton}" HorizontalAlignment="Right"
                            Width="28" Height="28" Padding="0" Click="CloseButton_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{StaticResource Text500Brush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- 路径表单 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24">
                    <TextBlock Text="游戏安装路径" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource CyberTextBox}"
                                 Text="{Binding GamePath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource CyberSecondaryButton}"
                                Width="72" Height="40" Margin="8,0,0,0"
                                Command="{Binding BrowseGamePathCommand}"/>
                    </Grid>

                    <TextBlock Text="MOD 文件夹路径" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource CyberTextBox}"
                                 Text="{Binding ModPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource CyberSecondaryButton}"
                                Width="72" Height="40" Margin="8,0,0,0"
                                Command="{Binding BrowseModPathCommand}"/>
                    </Grid>

                    <TextBlock Text="备份文件夹路径" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource CyberTextBox}"
                                 Text="{Binding BackupPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="浏览" Style="{StaticResource CyberSecondaryButton}"
                                Width="72" Height="40" Margin="8,0,0,0"
                                Command="{Binding BrowseBackupPathCommand}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="2" BorderBrush="#99272727" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,16">
                    <Button Content="取消" Style="{StaticResource CyberSecondaryButton}"
                            Width="80" Height="36" Margin="0,0,12,0"
                            Command="{Binding CancelCommand}"/>
                    <Button Content="确认" Style="{StaticResource CyberPrimaryButton}"
                            Width="80" Height="36"
                            Command="{Binding ConfirmCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
