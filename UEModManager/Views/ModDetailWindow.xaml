<Window x:Class="UEModManager.Views.ModDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MOD 详情"
        Width="520" SizeToContent="Height"
        MaxHeight="720"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource CyberModalWindow}"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="0">
        <!-- 预览图区域 -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="260"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部预览图 -->
            <Border Grid.Row="0" Background="{StaticResource BgBaseBrush}" ClipToBounds="True">
                <Grid>
                    <Image x:Name="PreviewImage" Stretch="UniformToFill"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <!-- 无图占位 -->
                    <Border x:Name="NoPreviewPlaceholder" Background="{StaticResource BgBaseBrush}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🖼" FontSize="48" HorizontalAlignment="Center"
                                       Foreground="{StaticResource Text700Brush}"/>
                            <TextBlock Text="无预览图" FontSize="13" Margin="0,8,0,0"
                                       Foreground="{StaticResource Text600Brush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 状态标签 (左上角) -->
                    <Border x:Name="StatusBadge" HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="16,16,0,0" CornerRadius="6" Padding="10,4">
                        <TextBlock x:Name="StatusText" FontSize="12" FontWeight="Medium"/>
                    </Border>

                    <!-- 关闭按钮 (右上角) -->
                    <Border Width="32" Height="32" CornerRadius="16"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,12,12,0" Cursor="Hand"
                            MouseLeftButtonDown="CloseBtn_Click">
                        <Border.Background>
                            <SolidColorBrush Color="Black" Opacity="0.5"/>
                        </Border.Background>
                        <TextBlock Text="✕" FontSize="14" Foreground="{StaticResource Text300Brush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- 信息区域 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,24">

                    <!-- MOD 名称 -->
                    <TextBlock x:Name="ModNameText" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource Text100Brush}"
                               TextWrapping="Wrap" Margin="0,0,0,4"/>

                    <!-- 真实文件名 -->
                    <TextBlock x:Name="RealNameText" FontSize="12"
                               Foreground="{StaticResource Text500Brush}"
                               TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- 信息网格 -->
                    <Border CornerRadius="12" Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                            Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 分类 -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="分类"
                                       Foreground="{StaticResource Text500Brush}" FontSize="13"
                                       Margin="0,0,24,12"/>
                            <TextBlock x:Name="CategoryText" Grid.Row="0" Grid.Column="1"
                                       Foreground="{StaticResource Text200Brush}" FontSize="13"
                                       Margin="0,0,0,12"/>

                            <!-- 文件大小 -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="大小"
                                       Foreground="{StaticResource Text500Brush}" FontSize="13"
                                       Margin="0,0,24,12"/>
                            <TextBlock x:Name="FileSizeText" Grid.Row="1" Grid.Column="1"
                                       Foreground="{StaticResource Text200Brush}" FontSize="13"
                                       Margin="0,0,0,12"/>

                            <!-- 安装日期 -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="安装日期"
                                       Foreground="{StaticResource Text500Brush}" FontSize="13"
                                       Margin="0,0,24,12"/>
                            <TextBlock x:Name="InstallDateText" Grid.Row="2" Grid.Column="1"
                                       Foreground="{StaticResource Text200Brush}" FontSize="13"
                                       Margin="0,0,0,12"/>

                            <!-- 备份状态 -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="备份"
                                       Foreground="{StaticResource Text500Brush}" FontSize="13"
                                       Margin="0,0,24,12"/>
                            <TextBlock x:Name="BackupStatusText" Grid.Row="3" Grid.Column="1"
                                       Foreground="{StaticResource Text200Brush}" FontSize="13"
                                       Margin="0,0,0,12"/>

                            <!-- 文件夹路径 -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="路径"
                                       Foreground="{StaticResource Text500Brush}" FontSize="13"
                                       Margin="0,0,24,0"/>
                            <TextBlock x:Name="FolderPathText" Grid.Row="4" Grid.Column="1"
                                       Foreground="{StaticResource Text500Brush}" FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        </Grid>
                    </Border>

                    <!-- 描述 (可选) -->
                    <StackPanel x:Name="DescriptionPanel" Visibility="Collapsed" Margin="0,0,0,16">
                        <TextBlock Text="描述" Foreground="{StaticResource Text500Brush}"
                                   FontSize="12" FontWeight="Medium" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DescriptionText" Foreground="{StaticResource Text300Brush}"
                                   FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- 操作按钮区 -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ToggleBtn" Grid.Column="0" Content="启用MOD"
                                Height="36" Style="{StaticResource CyberPrimaryButton}"
                                Click="ToggleBtn_Click" HorizontalAlignment="Stretch" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="预览图" Height="36" Width="72"
                                Style="{StaticResource CyberSecondaryButton}"
                                Click="ChangePreviewBtn_Click" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="编辑" Height="36" Width="60"
                                Style="{StaticResource CyberSecondaryButton}"
                                Click="RenameBtn_Click" Margin="0,0,8,0"/>
                        <Button Grid.Column="3" Content="删除" Height="36" Width="60"
                                Style="{StaticResource CyberSecondaryButton}"
                                Foreground="{StaticResource StatusRedBrush}"
                                Click="DeleteBtn_Click"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
