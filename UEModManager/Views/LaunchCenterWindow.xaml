<Window x:Class="UEModManager.Views.LaunchCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="启动中心" Height="560" Width="760"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBaseBrush}"
        Style="{StaticResource CyberDarkWindow}">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow"/>
        <CommandBinding Command="{x:Static SystemCommands.MinimizeWindowCommand}" Executed="OnMinimizeWindow"/>
    </Window.CommandBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════ 左侧边栏 ═══════ -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <!-- Logo/标题 -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,0">
                    <TextBlock Text="游戏MOD管理器" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource Text100Brush}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="SidebarProfileText" Text="方案: 默认" FontSize="11"
                               Foreground="{StaticResource Text400Brush}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- 分隔 -->
                <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource CyberBorderBrush}" Margin="16,16,16,8"/>

                <!-- 导航项 -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0">
                    <!-- 启动预检（当前页，高亮） -->
                    <Border CornerRadius="8" Padding="12,10" Margin="0,2"
                            Background="#0d06b6d4" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M5,3 L19,12 L5,21 Z" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="2"
                                          StrokeLineJoin="Round"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="启动预检" FontSize="13" Foreground="{StaticResource PrimaryLightBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 启动历史 -->
                    <Border CornerRadius="8" Padding="12,10" Margin="0,2" Cursor="Hand"
                            MouseLeftButtonDown="ShowHistory_Click">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,10,0">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12 8V12L15 15M21 12C21 16.97 16.97 21 12 21C7.03 21 3 16.97 3 12C3 7.03 7.03 3 12 3C16.97 3 21 7.03 21 12Z"
                                          Stroke="{StaticResource Text400Brush}" StrokeThickness="2" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="启动历史" FontSize="13" Foreground="{StaticResource Text400Brush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 底部信息 -->
                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,16" VerticalAlignment="Bottom">
                    <Border Height="1" Background="{StaticResource CyberBorderBrush}" Margin="0,0,0,12"/>
                    <TextBlock x:Name="SidebarGameInfo" Text="" FontSize="10"
                               Foreground="{StaticResource Text500Brush}" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- 填充 -->
                <Border/>
            </DockPanel>
        </Border>

        <!-- ═══════ 右侧主内容 ═══════ -->
        <DockPanel Grid.Column="1" Margin="40,32">
            <!-- 标题区 -->
            <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,0,0,28">
                <TextBlock x:Name="TitleText" Text="准备启动" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource Text100Brush}" HorizontalAlignment="Center"
                           FontFamily="{StaticResource InterFont}"/>
                <TextBlock x:Name="SubtitleText" Text="" FontSize="13"
                           Foreground="{StaticResource Text400Brush}" HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <!-- 底部状态栏 -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,20,0,0">
                <TextBlock x:Name="LastLaunchText" Text="首次启动" FontSize="11"
                           Foreground="{StaticResource Text500Brush}" Margin="0,0,20,0"/>
                <Ellipse Width="4" Height="4" Fill="{StaticResource Text600Brush}" VerticalAlignment="Center"
                         Margin="0,0,20,0"/>
                <TextBlock x:Name="ModCountText" Text="0 个包已启用" FontSize="11"
                           Foreground="{StaticResource Text500Brush}" Margin="0,0,20,0"/>
                <Ellipse Width="4" Height="4" Fill="{StaticResource Text600Brush}" VerticalAlignment="Center"
                         Margin="0,0,20,0"/>
                <TextBlock x:Name="LastEventText" Text="上次事件: 无异常" FontSize="11"
                           Foreground="{StaticResource Text500Brush}"/>
            </StackPanel>

            <!-- 中间内容 -->
            <StackPanel VerticalAlignment="Center">
                <!-- 启动前检查标题 -->
                <TextBlock Text="启动前检查" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource Text200Brush}" Margin="0,0,0,16"/>

                <!-- 检查列表 -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12"
                        BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                        Padding="20,16" Margin="0,0,0,28">
                    <StackPanel x:Name="CheckListPanel" />
                </Border>

                <!-- 启动按钮 -->
                <Border x:Name="LaunchButton" CornerRadius="14" Padding="0" Height="52"
                        HorizontalAlignment="Center" MinWidth="240"
                        Cursor="Hand" MouseLeftButtonDown="LaunchButton_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect ShadowDepth="0" BlurRadius="24"
                                                              Color="#06b6d4" Opacity="0.6"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Viewbox Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Path x:Name="LaunchIcon" Data="M5,3 L19,12 L5,21 Z"
                                      Stroke="{StaticResource BgBaseBrush}" StrokeThickness="2"
                                      StrokeLineJoin="Round"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock x:Name="LaunchButtonText" Text="启动游戏" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource BgBaseBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 启动进度条（运行时显示） -->
                <Border x:Name="ProgressArea" Visibility="Collapsed" Margin="0,16,0,0">
                    <StackPanel>
                        <ProgressBar x:Name="LaunchProgress" Height="4" IsIndeterminate="True"
                                     Foreground="{StaticResource PrimaryBrush}"
                                     Background="{StaticResource CyberBorderBrush}" BorderThickness="0"/>
                        <TextBlock x:Name="ProgressText" Text="正在启动..."
                                   FontSize="12" Foreground="{StaticResource Text400Brush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
