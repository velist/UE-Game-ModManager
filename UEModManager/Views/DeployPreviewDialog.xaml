<Window x:Class="UEModManager.Views.DeployPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:UEModManager.Converters"
        Title="应用 MOD 前确认" Height="520" Width="540"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource CyberModalWindow}">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow"/>
    </Window.CommandBindings>

    <Window.Resources>
        <converters:DeployOpTypeToBrushConverter x:Key="OpTypeBrush"/>
        <converters:DeployOpTypeToLabelConverter x:Key="OpTypeLabel"/>
        <converters:FileSizeConverter x:Key="FileSizeConv"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 标题 -->
            <RowDefinition Height="Auto"/>
            <!-- 说明 -->
            <RowDefinition Height="Auto"/>
            <!-- 统计卡片 -->
            <RowDefinition Height="Auto"/>
            <!-- 变更文件列表 -->
            <RowDefinition Height="*"/>
            <!-- 底部按钮 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ 标题 ═══ -->
        <Border Grid.Row="0" Padding="24,20,24,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,10,0"
                           VerticalAlignment="Center"/>
                <TextBlock Text="应用 MOD 前确认" FontSize="17" FontWeight="SemiBold"
                           Foreground="{StaticResource Text100Brush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ═══ 说明 ═══ -->
        <TextBlock Grid.Row="1" Text="以下文件将写入、修改或移出游戏目录，确认后生效"
                   FontSize="13" Foreground="{StaticResource Text400Brush}"
                   Margin="24,0,24,16"/>

        <!-- ═══ 统计卡片行 ═══ -->
        <Grid Grid.Row="2" Margin="24,0,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 新增 -->
            <Border Grid.Column="0" Background="#1822c55e" CornerRadius="{StaticResource RadiusSm}"
                    Padding="14,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="#22c55e" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="AddCountText" Text="0 文件" FontSize="16" FontWeight="Bold"
                                   Foreground="#22c55e"/>
                    </StackPanel>
                    <TextBlock Text="新增" FontSize="11" Foreground="{StaticResource Text500Brush}"/>
                </StackPanel>
            </Border>

            <!-- 修改 -->
            <Border Grid.Column="2" Background="#18f59e0b" CornerRadius="{StaticResource RadiusSm}"
                    Padding="14,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="#f59e0b" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ReplaceCountText" Text="0 文件" FontSize="16" FontWeight="Bold"
                                   Foreground="#f59e0b"/>
                    </StackPanel>
                    <TextBlock Text="修改" FontSize="11" Foreground="{StaticResource Text500Brush}"/>
                </StackPanel>
            </Border>

            <!-- 移除 -->
            <Border Grid.Column="4" Background="#18ef4444" CornerRadius="{StaticResource RadiusSm}"
                    Padding="14,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="#ef4444" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="RemoveCountText" Text="0 文件" FontSize="16" FontWeight="Bold"
                                   Foreground="#ef4444"/>
                    </StackPanel>
                    <TextBlock Text="移除" FontSize="11" Foreground="{StaticResource Text500Brush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ 变更文件列表 ═══ -->
        <Border Grid.Row="3" Margin="24,0,24,0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 列表头 -->
                <Border Grid.Row="0" Padding="14,8" BorderBrush="{StaticResource CyberBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="即将影响的文件" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource Text300Brush}"/>
                </Border>

                <!-- 操作列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,4,0,4">
                    <StackPanel x:Name="OperationListPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══ 底部按钮 ═══ -->
        <Border Grid.Row="4" Padding="24,16,24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="取消" Click="CancelButton_Click"
                        Style="{StaticResource CyberSecondaryButton}"
                        Width="70" Height="36" Margin="0,0,10,0"/>
                <Button Grid.Column="2" x:Name="DeployButton" Click="DeployButton_Click"
                        Style="{StaticResource CyberPrimaryButton}"
                        Height="38" Padding="16,0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="确认应用" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ 部署进度遮罩 ═══ -->
        <Grid Grid.RowSpan="6" x:Name="DeployProgressOverlay" Visibility="Collapsed"
              Background="#E0030303">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar x:Name="DeployProgress" Width="260" Height="4"
                             Style="{StaticResource CyberProgressBar}" Margin="0,0,0,12"/>
                <TextBlock x:Name="DeployStatusText" Text="正在应用 MOD..."
                           FontSize="14" Foreground="{StaticResource Text200Brush}"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock x:Name="DeployDetailText" Text=""
                           FontSize="12" Foreground="{StaticResource Text500Brush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
