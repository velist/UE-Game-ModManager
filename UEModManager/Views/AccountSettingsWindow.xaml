<Window x:Class="UEModManager.Views.AccountSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="账户设置" Height="435" Width="420"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource CyberModalWindow}">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow"/>
    </Window.CommandBindings>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 头像区 -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Border Width="80" Height="80" CornerRadius="40" BorderBrush="{StaticResource CyberBorderBrush}"
                    BorderThickness="2" HorizontalAlignment="Center" Margin="0,0,0,12">
                <Border CornerRadius="40" ClipToBounds="True">
                    <Image x:Name="AvatarPreview" Width="76" Height="76" Stretch="UniformToFill"/>
                </Border>
            </Border>
            <Button Content="更换头像" Style="{StaticResource CyberSecondaryButton}"
                    Height="32" Click="ChangeAvatar_Click"/>
        </StackPanel>

        <!-- 表单 -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="用户名" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
            <TextBox x:Name="UsernameTextBox" Style="{StaticResource CyberTextBox}" Margin="0,0,0,16"/>

            <TextBlock Text="显示名称" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
            <TextBox x:Name="DisplayNameTextBox" Style="{StaticResource CyberTextBox}" Margin="0,0,0,16"/>

            <TextBlock Text="个性签名" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
            <TextBox x:Name="SignatureTextBox" Style="{StaticResource CyberTextBox}" Height="60"
                     AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="14,10"/>
        </StackPanel>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="取消" Style="{StaticResource CyberSecondaryButton}"
                    Width="80" Height="36" Margin="0,0,12,0" Click="Cancel_Click"/>
            <Button Content="保存" Style="{StaticResource CyberPrimaryButton}"
                    Width="80" Height="36" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
