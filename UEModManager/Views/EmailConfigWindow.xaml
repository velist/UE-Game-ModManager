<Window x:Class="UEModManager.Views.EmailConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="邮件服务配置" Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Style="{StaticResource CyberModalWindow}">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow"/>
    </Window.CommandBindings>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <TextBlock Text="邮件服务配置" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource Text100Brush}" Margin="0,0,0,20"/>

                <!-- 提供商 -->
                <TextBlock Text="邮件提供商" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                <ComboBox x:Name="ProviderComboBox" Style="{StaticResource CyberComboBox}"
                          SelectionChanged="ProviderComboBox_SelectionChanged" Margin="0,0,0,16"/>

                <!-- 发件人邮箱 -->
                <TextBlock Text="发件人邮箱" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                <TextBox x:Name="SenderEmailTextBox" Style="{StaticResource CyberTextBox}" Margin="0,0,0,16"/>

                <!-- 授权密码 -->
                <TextBlock Text="授权密码/API Key" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="SenderPasswordBox" Style="{StaticResource CyberPasswordBox}" Margin="0,0,0,4"/>
                <TextBlock x:Name="PasswordHintTextBlock" FontSize="11"
                           Foreground="{StaticResource Text500Brush}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- 发件人名称 -->
                <TextBlock Text="发件人名称" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                <TextBox x:Name="SenderNameTextBox" Style="{StaticResource CyberTextBox}" Margin="0,0,0,16"/>

                <!-- 自定义SMTP配置 -->
                <StackPanel x:Name="CustomConfigPanel" Visibility="Collapsed" Margin="0,0,0,16">
                    <TextBlock Text="SMTP 服务器" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                    <TextBox x:Name="SmtpServerTextBox" Style="{StaticResource CyberTextBox}" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="SMTP 端口" Style="{StaticResource CyberLabel}" Margin="0,0,0,6"/>
                            <TextBox x:Name="SmtpPortTextBox" Style="{StaticResource CyberTextBox}"/>
                        </StackPanel>
                        <CheckBox x:Name="EnableSslCheckBox" Grid.Column="1" Content="SSL"
                                  Style="{StaticResource CyberCheckBox}" VerticalAlignment="Bottom"
                                  Margin="16,0,0,10"/>
                    </Grid>
                </StackPanel>

                <!-- 测试 -->
                <Button x:Name="TestConfigButton" Content="测试配置"
                        Style="{StaticResource CyberSecondaryButton}"
                        Height="36" Width="100" HorizontalAlignment="Left"
                        Margin="0,0,0,8" Click="TestConfig_Click"/>
                <TextBlock x:Name="TestResultTextBlock" FontSize="12"
                           Foreground="{StaticResource Text500Brush}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                <!-- 底部按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Style="{StaticResource CyberSecondaryButton}"
                            Width="80" Height="36" Margin="0,0,12,0" Click="Cancel_Click"/>
                    <Button Content="保存" Style="{StaticResource CyberPrimaryButton}"
                            Width="80" Height="36" Click="Save_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="LoadingOverlay" Background="#E6030303" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Width="120" Height="4" IsIndeterminate="True"
                             Style="{StaticResource CyberProgressBar}" Margin="0,0,0,12"/>
                <TextBlock x:Name="LoadingText" Text="处理中..."
                           Foreground="{StaticResource Text300Brush}" FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
