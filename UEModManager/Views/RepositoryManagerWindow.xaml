<Window x:Class="UEModManager.Views.RepositoryManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:UEModManager.Converters"
        Title="MOD 存储管理" Height="560" Width="540"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource CyberModalWindow}">

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="OnCloseWindow"/>
    </Window.CommandBindings>

    <Window.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConv"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 标题 -->
            <RowDefinition Height="Auto"/>
            <!-- 统计卡片 -->
            <RowDefinition Height="Auto"/>
            <!-- 包列表 -->
            <RowDefinition Height="*"/>
            <!-- 底部操作按钮 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ 标题 ═══ -->
        <Border Grid.Row="0" Padding="24,20,24,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xEDA2;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,10,0"
                           VerticalAlignment="Center"/>
                <TextBlock Text="MOD 存储管理" FontSize="17" FontWeight="SemiBold"
                           Foreground="{StaticResource Text100Brush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ═══ 统计卡片行 ═══ -->
        <Grid Grid.Row="1" Margin="24,0,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 总占用空间 -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}" Padding="12,10">
                <StackPanel>
                    <TextBlock x:Name="TotalSizeText" Text="0 B" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Text100Brush}"/>
                    <TextBlock Text="总占用空间" FontSize="10" Foreground="{StaticResource Text500Brush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- 总包数量 -->
            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}" Padding="12,10">
                <StackPanel>
                    <TextBlock x:Name="TotalCountText" Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Text100Brush}"/>
                    <TextBlock Text="MOD 数量" FontSize="10" Foreground="{StaticResource Text500Brush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- 未引用包 -->
            <Border Grid.Column="4" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}" Padding="12,10">
                <StackPanel>
                    <TextBlock x:Name="OrphanCountText" Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="#f59e0b"/>
                    <TextBlock Text="未使用" FontSize="10" Foreground="{StaticResource Text500Brush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- 重复包 -->
            <Border Grid.Column="6" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                    CornerRadius="{StaticResource RadiusSm}" Padding="12,10">
                <StackPanel>
                    <TextBlock x:Name="DuplicateCountText" Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="#ef4444"/>
                    <TextBlock Text="重复文件" FontSize="10" Foreground="{StaticResource Text500Brush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ 包列表表格 ═══ -->
        <Border Grid.Row="2" Margin="24,0,24,0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource CyberBorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource RadiusSm}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 表头 -->
                <Border Grid.Row="0" Padding="14,8" BorderBrush="{StaticResource CyberBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="MOD 名称" FontSize="11"
                                   Foreground="{StaticResource Text500Brush}"/>
                        <TextBlock Grid.Column="1" Text="大小" FontSize="11"
                                   Foreground="{StaticResource Text500Brush}" TextAlignment="Right"/>
                        <TextBlock Grid.Column="2" Text="使用情况" FontSize="11"
                                   Foreground="{StaticResource Text500Brush}" TextAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="状态" FontSize="11"
                                   Foreground="{StaticResource Text500Brush}" TextAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- 包列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PackageListPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══ 底部操作按钮 ═══ -->
        <Border Grid.Row="3" Padding="24,16,24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Click="CheckIntegrity_Click"
                        Style="{StaticResource CyberSecondaryButton}"
                        Height="36" Padding="12,0" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="检查缺失文件" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Click="MergeDuplicates_Click"
                        Style="{StaticResource CyberSecondaryButton}"
                        Height="36" Padding="12,0" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="合并相同文件" FontSize="12"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" x:Name="CleanupButton" Click="CleanupOrphans_Click"
                        Style="{StaticResource CyberPrimaryButton}"
                        Height="38" Padding="14,0" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CleanupButtonText" Text="清理未使用" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
